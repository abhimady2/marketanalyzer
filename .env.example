# Copy to .env.local and fill. Server-only (never NEXT_PUBLIC — provider keys must not reach the browser).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=some-long-random-string
INGEST_SECRET=shared-secret-the-mt5-EA-sends

# Optional but recommended: free key from https://fredaccount.stlouisfed.org/apikeys
# Enables the macro liquidity bucket on Vercel — datacenter IPs block FRED's keyless CSV.
FRED_API_KEY=
